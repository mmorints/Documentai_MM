public class Main {

    public static void main(String[] args) {
        System.out.println("Hello from a simple Java project!");

        int a = 5;
        int b = 7;
        int sum = add(a, b);

        System.out.println("Sum of " + a + " and " + b + " is: " + sum);
    }

    public static int add(int x, int y) {
        return x + y;
    }
}
